# Database (PostgreSQL) - Neon example
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# Admin: set to "true" to bypass login for /admin (development only)
BYPASS_ADMIN_AUTH=""

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional - omit to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_LINE_ID=""
AUTH_LINE_SECRET=""

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: file upload (Vercel Blob or S3) - required for payment proof upload
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Thai payments (Phase 1)
PROMPTPAY_ID="0812345678"
BANK_NAME="Kasikorn Bank (KBank)"
BANK_BRANCH="Head Office"
BANK_ACCOUNT_NAME="SiamEZ Professional Services Co., Ltd."
BANK_ACCOUNT_NUMBER="123-4-56789-0"
WISE_BENEFICIARY="SiamEZ Professional Services Co., Ltd."
WISE_DETAILS="Bank: Kasikorn Bank\nAccount: 123-4-56789-0\nReference: [Your invoice reference]"
