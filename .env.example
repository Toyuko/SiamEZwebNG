# Database (MySQL) - use for local and Vercel (e.g. PlanetScale, Neon, or Vercel Postgres MySQL)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?schema=public"

# NextAuth (or custom auth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: file upload (Vercel Blob or S3)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."
