# Database (PostgreSQL) - Neon example
# Use the pooled connection for the app runtime:
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require"
# Use the direct (non-pooler) connection for prisma migrate deploy:
# Same as DATABASE_URL but without "-pooler" in the hostname.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DATABASE?sslmode=require"

# Optional seed overrides (defaults shown)
# SEED_ADMIN_EMAIL="admin@siamez.com"
# SEED_ADMIN_PASSWORD="ChangeMeInProduction!"
# SEED_CUSTOMER_EMAIL="customer@example.com"
# SEED_CUSTOMER_PASSWORD="Customer123!"
# SEED_FREELANCER_EMAIL="freelancer@example.com"
# SEED_FREELANCER_PASSWORD="Freelancer123!"

# Admin: set to "true" to bypass login for /admin (development only)
BYPASS_ADMIN_AUTH=""

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Vercel Cron: auto-approve completed freelancer jobs (Bearer token)
# No leading/trailing spaces or newlines (Vercel rejects whitespace in cron header values).
CRON_SECRET=generate-a-random-secret

# OAuth providers (optional - omit to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
# Feature flag: keep Facebook button hidden until review is approved.
AUTH_ENABLE_FACEBOOK="false"
AUTH_LINE_ID=""
AUTH_LINE_SECRET=""

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: file upload (Vercel Blob or S3) - required for payment proof upload
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Real-time job chat (Pusher) - https://pusher.com
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# Webhook for email/push notifications (contact form, job updates, chat messages)
CONTACT_FORM_WEBHOOK_URL=""

# Thai payments (Phase 1)
PROMPTPAY_ID="0812345678"
BANK_NAME="Kasikorn Bank (KBank)"
BANK_BRANCH="Head Office"
BANK_ACCOUNT_NAME="SiamEZ Professional Services Co., Ltd."
BANK_ACCOUNT_NUMBER="123-4-56789-0"
WISE_BENEFICIARY="SiamEZ Professional Services Co., Ltd."
WISE_DETAILS="Bank: Kasikorn Bank\nAccount: 123-4-56789-0\nReference: [Your invoice reference]"
