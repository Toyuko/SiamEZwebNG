// SiamEZ Platform - PostgreSQL schema
// Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon pooler does not support session advisory locks used by migrate.
  // Set DIRECT_URL to the non-pooler host (strip "-pooler" from the hostname).
  directUrl = env("DIRECT_URL")
}

// ----- Users & Auth -----

enum UserRole {
  admin
  staff
  customer
  freelancer
  company
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  passwordHash   String?   @map("password_hash")
  name           String?
  phone          String?
  image          String?
  timezone       String?
  preferredLocale String?  @map("preferred_locale")
  notificationPreferences Json? @map("notification_preferences")
  expoPushToken  String?   @map("expo_push_token")
  lastLoginAt    DateTime? @map("last_login_at")
  role           UserRole  @default(customer)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  casesAsClient  Case[]            @relation("CaseClient")
  staffAssignments StaffAssignment[]
  caseNotes      CaseNote[]
  documents      Document[]        @relation("DocumentUploader")
  invoices       Invoice[]         @relation("InvoiceCustomer")
  eventsAsClient Event[]           @relation("EventClient")
  eventsAsStaff  Event[]           @relation("EventStaff")
  salesVehiclesCreated SalesVehicle[]
  salesPropertiesCreated SalesProperty[]
  freelancerProfile   FreelancerProfile?
  company             Company?
  jobsPosted          Job[]              @relation("JobPostedBy")
  jobsAsFreelancer    Job[]              @relation("JobFreelancer")
  marketplaceJobs     MarketplaceJob[]   @relation("MarketplaceJobFreelancer")
  jobApplications     JobApplication[]   @relation("JobApplicationFreelancer")
  reviewsAsClient     Review[]           @relation("ReviewClient")
  reviewsAsFreelancer Review[]           @relation("ReviewFreelancer")
}

enum FreelancerVerificationStatus {
  pending
  verified
  rejected
}

model FreelancerProfile {
  id                 String                       @id @default(cuid())
  userId             String                       @unique @map("user_id")
  /// URL-safe public username (e.g. /freelancers/sam-translator). Null until claimed.
  slug               String?                      @unique
  isPublic           Boolean                      @default(false) @map("is_public")
  /// Professional headline, e.g. "Certified Translator"
  title              String?
  skills             String[]                     @default([])
  bio                String?                      @db.Text
  /// Hourly rate in smallest currency unit (satang). Null = not listed.
  hourlyRate         Int?                         @map("hourly_rate")
  /// Structured service offerings: [{ title, description?, price? (satang), currency? }]
  services           Json                         @default("[]")
  verificationStatus FreelancerVerificationStatus @default(pending) @map("verification_status")
  isSpecialMember    Boolean                      @default(false) @map("is_special_member")
  averageRating      Float                        @default(0) @map("average_rating")
  totalReviews       Int                          @default(0) @map("total_reviews")
  expoPushToken      String?                      @map("expo_push_token")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublic])
  @@map("freelancer_profiles")
}

// ----- Corporate / Company tier -----

enum JobPostingStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum JobApplicationStatus {
  PENDING
  HIRED
  DECLINED
}

enum AdCampaignStatus {
  PENDING
  ACTIVE
  PAUSED
}

model Company {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  slug         String   @unique
  companyName  String   @map("company_name")
  logo         String?
  bannerImage  String?  @map("banner_image")
  website      String?
  description  String?  @db.Text
  industry     String?
  companySize  String?  @map("company_size")
  taxId        String?  @map("tax_id")
  address      String?
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostings  JobPosting[]
  adCampaigns  AdCampaign[]

  @@map("companies")
}

model JobPosting {
  id             String           @id @default(cuid())
  companyId      String           @map("company_id")
  title          String
  description    String           @db.Text
  budget         Int
  currency       String           @default("THB")
  requiredSkills String[]         @default([]) @map("required_skills")
  status         JobPostingStatus @default(OPEN)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([companyId, status])
  @@index([status])
  @@map("job_postings")
}

model JobApplication {
  id           String               @id @default(cuid())
  jobPostingId String               @map("job_posting_id")
  freelancerId String               @map("freelancer_id")
  coverNote    String?              @map("cover_note") @db.Text
  status       JobApplicationStatus @default(PENDING)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  freelancer User       @relation("JobApplicationFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, freelancerId])
  @@index([freelancerId])
  @@index([jobPostingId, status])
  @@map("job_applications")
}

model AdCampaign {
  id          String           @id @default(cuid())
  companyId   String           @map("company_id")
  title       String
  imageUrl    String           @map("image_url")
  targetUrl   String           @map("target_url")
  budget      Int
  dailyLimit  Int?             @map("daily_limit")
  impressions Int              @default(0)
  clicks      Int              @default(0)
  status      AdCampaignStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([status])
  @@map("ad_campaigns")
}

enum AssignmentSource {
  internal
  freelancer
}

enum JobStatus {
  open
  in_progress
  completed_awaiting_review
  approved
  completed
}

/// Step-level progress for driver-license and vehicle-registration marketplace jobs.
enum TrackingStatus {
  DOCUMENTS_PENDING
  APPOINTMENT_SET
  DLT_EXAM_PREP
  LICENSE_ISSUED
  POR_ROR_BOR_PAID
  DLT_INSPECTION
  PLATES_ISSUED
  DELIVERED
}

model Job {
  id                      String           @id @default(cuid())
  title                   String
  description             String           @db.Text
  postedById              String           @map("posted_by_id")
  freelancerId            String?          @map("freelancer_id")
  serviceId               String?          @map("service_id")
  assignmentSource        AssignmentSource @default(freelancer) @map("assignment_source")
  /** Client-facing / invoice amount (smallest currency unit) */
  amount                  Int
  /** Freelancer payout (smallest currency unit); defaults to amount when unset */
  payoutAmount            Int?             @map("payout_amount")
  currency                String           @default("THB")
  isSpecialMemberOnly     Boolean          @default(false) @map("is_special_member_only")
  enableAutoApproval      Boolean          @default(true) @map("enable_auto_approval")
  status                  JobStatus        @default(open)
  trackingStatus          TrackingStatus?  @map("tracking_status")
  trackingNotes           String?          @map("tracking_notes") @db.Text
  isCurrentlyInTransit    Boolean          @default(false) @map("is_currently_in_transit")
  completionSubmittedAt   DateTime?        @map("completion_submitted_at")
  approvedAt              DateTime?        @map("approved_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  postedBy         User                  @relation("JobPostedBy", fields: [postedById], references: [id], onDelete: Restrict)
  freelancer       User?                 @relation("JobFreelancer", fields: [freelancerId], references: [id], onDelete: SetNull)
  service          Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  trackingHistory  JobTrackingHistory[]
  conversation     Conversation?
  review           Review?

  @@index([status])
  @@index([assignmentSource, status])
  @@index([freelancerId, status])
  @@index([postedById])
  @@map("jobs")
}

model JobTrackingHistory {
  id             String         @id @default(cuid())
  jobId          String         @map("job_id")
  status         TrackingStatus
  note           String?        @db.Text
  attachmentUrl  String?        @map("attachment_url")
  attachmentName String?        @map("attachment_name")
  latitude       Float?
  longitude      Float?
  createdAt      DateTime       @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("job_tracking_history")
}

model Review {
  id           String   @id @default(cuid())
  rating       Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  jobId        String   @unique @map("job_id")
  clientId     String   @map("client_id")
  freelancerId String   @map("freelancer_id")

  job        Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  client     User @relation("ReviewClient", fields: [clientId], references: [id], onDelete: Restrict)
  freelancer User @relation("ReviewFreelancer", fields: [freelancerId], references: [id], onDelete: Restrict)

  @@index([freelancerId, createdAt])
  @@index([clientId])
  @@map("reviews")
}

model Conversation {
  id        String   @id @default(cuid())
  jobId     String   @unique @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job      Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  receiverId     String   @map("receiver_id")
  content        String   @db.Text
  attachmentUrl  String?  @map("attachment_url")
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ----- Services -----

enum ServiceType {
  fixed   // Pay immediately
  quote   // Request review, admin sets price, client pays later
}

model Service {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  shortDescription String? @map("short_description") @db.VarChar(500)
  description String      @db.Text
  type        ServiceType @default(quote)
  priceAmount Int?        @map("price_amount")   // in smallest currency unit (e.g. cents)
  priceCurrency String?   @map("price_currency") @default("THB")
  // JSON: dynamic form config (questions, required docs, etc.)
  formConfig  Json?       @map("form_config")
  sortOrder   Int         @default(0) @map("sort_order")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  cases Case[]
  jobs  Job[]
}

// ----- Cases (every booking becomes a case) -----

enum CaseStatus {
  new           // Just submitted
  under_review  // Staff reviewing (quote-based)
  quoted        // Quote sent to client
  awaiting_payment
  paid          // Payment received
  in_progress   // Work in progress
  pending_docs  // Waiting for client docs
  completed
  cancelled
}

model Case {
  id                   String     @id @default(cuid())
  caseNumber           String     @unique @map("case_number") // e.g. SE-2026-00001
  userId               String?    @map("user_id") // null for guest bookings
  serviceId            String     @map("service_id")
  status               CaseStatus @default(new)
  isGuest              Boolean    @default(false) @map("is_guest")
  guestCheckoutToken   String?    @unique @map("guest_checkout_token") // for secure guest checkout
  guestEmail          String?    @map("guest_email")
  guestName           String?    @map("guest_name")
  guestPhone          String?    @map("guest_phone")
  formData            Json?      @map("form_data")
  postToMarketplace   Boolean    @default(false) @map("post_to_marketplace")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  completedAt         DateTime?  @map("completed_at")

  user            User?            @relation("CaseClient", fields: [userId], references: [id], onDelete: SetNull)
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quotes          Quote[]
  payments        Payment[]
  documents       Document[]
  staffAssignments StaffAssignment[]
  caseNotes       CaseNote[]
  invoices        Invoice[]
  events          Event[]
  marketplaceJob  MarketplaceJob?
}

enum MarketplaceJobStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

model MarketplaceJob {
  id            String               @id @default(cuid())
  caseId        String               @unique @map("case_id")
  status        MarketplaceJobStatus @default(OPEN)
  /** Freelancer payout in smallest currency unit (e.g. satang) */
  budget        Int
  freelancerId  String?              @map("freelancer_id")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  case       Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  freelancer User? @relation("MarketplaceJobFreelancer", fields: [freelancerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([freelancerId])
  @@map("marketplace_jobs")
}

// ----- Quotes -----

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
}

model Quote {
  id         String      @id @default(cuid())
  caseId     String      @map("case_id")
  amount     Int         // smallest currency unit
  currency   String      @default("THB")
  status     QuoteStatus @default(draft)
  validUntil DateTime?   @map("valid_until")
  notes      String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  sentAt     DateTime?   @map("sent_at")

  case    Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

// ----- Payments (provider-agnostic: QR, Bank, Wise, Stripe Phase 2) -----

enum PaymentMethod {
  qr      // Thai PromptPay / Bank QR
  bank    // Bank transfer
  wise    // Wise international
  stripe  // Phase 2: online payment
}

enum PaymentStatus {
  submitted   // Proof uploaded, awaiting admin review
  approved    // Admin approved -> invoice paid
  rejected    // Admin rejected
  // Stripe Phase 2: pending, succeeded, failed, refunded
}

model Payment {
  id                    String         @id @default(cuid())
  invoiceId             String         @map("invoice_id")
  caseId                String         @map("case_id") // denormalized for convenience
  amount                Int            // smallest unit
  currency              String         @default("THB")
  method                PaymentMethod
  status                PaymentStatus  @default(submitted)
  proofDocumentId       String?        @unique @map("proof_document_id")
  submittedAt           DateTime       @default(now()) @map("submitted_at")
  approvedAt            DateTime?      @map("approved_at")
  stripePaymentIntentId String?        @unique @map("stripe_payment_intent_id") // Phase 2
  stripeChargeId        String?        @map("stripe_charge_id")
  metadata              Json?
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Restrict)
  proofDocument Document? @relation("PaymentProof", fields: [proofDocumentId], references: [id], onDelete: SetNull)
}

// ----- Documents -----

model Document {
  id           String   @id @default(cuid())
  caseId       String?  @map("case_id") // null = not yet linked to a case
  uploadedBy   String?  @map("uploaded_by") // userId or null for system
  name         String
  storageKey   String   @map("storage_key") // Vercel Blob / S3 key or URL
  mimeType     String?  @map("mime_type")
  size         Int?     // bytes
  documentType String?  @map("document_type") // e.g. passport, contract, payment_proof
  createdAt    DateTime @default(now()) @map("created_at")

  case           Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  uploader       User?   @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
  paymentProof   Payment? @relation("PaymentProof")
}

// ----- Staff assignments -----

model StaffAssignment {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  userId    String   @map("user_id")
  role      String   @default("support") // primary, support
  assignedAt DateTime @default(now()) @map("assigned_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
  @@map("staff_assignments")
}

// ----- Case notes (internal + client-visible) -----

model CaseNote {
  id         String   @id @default(cuid())
  caseId     String   @map("case_id")
  userId     String   @map("user_id")
  content    String   @db.Text
  isInternal Boolean  @default(true) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("case_notes")
}

// ----- Invoices -----

enum InvoiceStatus {
  draft                // Admin editing
  unpaid               // Sent to client, awaiting payment
  pending_verification // Proof uploaded, admin reviewing
  paid                 // Payment approved
  rejected             // Payment rejected
}

enum InvoicePaymentMethod {
  qr     // Thai PromptPay / Bank QR
  bank   // Bank transfer
  wise   // Wise international
  stripe // Phase 2
}

model Invoice {
  id               String               @id @default(cuid())
  caseId           String               @map("case_id")
  quoteId          String?              @map("quote_id")
  userId           String?              @map("user_id") // billing contact; null for guest invoices
  amount           Int
  currency         String               @default("THB")
  status           InvoiceStatus        @default(draft)
  paymentMethod    InvoicePaymentMethod? @map("payment_method") // set when client selects
  dueDate          DateTime?            @map("due_date")
  stripeInvoiceId  String?              @map("stripe_invoice_id") // Phase 2
  lineItems        Json?                @map("line_items")
  attachedPdfUrl   String?              @map("attached_pdf_url") // admin-uploaded or external PDF (blob URL)
  clientAddress    String?              @map("client_address")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  sentAt           DateTime?            @map("sent_at")
  paidAt           DateTime?            @map("paid_at")

  case     Case     @relation(fields: [caseId], references: [id], onDelete: Restrict)
  quote    Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  user     User?    @relation("InvoiceCustomer", fields: [userId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@map("invoices")
}

// ----- Calendar Events -----

enum EventType {
  appointment
  deadline
  milestone
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  start       DateTime
  end         DateTime
  type        EventType @default(appointment)
  allDay      Boolean   @default(false) @map("all_day")
  color       String?   // optional: blue, red, emerald, amber, purple, cyan, pink, orange
  caseId      String?   @map("case_id")
  userId      String?   @map("user_id")   // client
  staffId     String?   @map("staff_id")  // assigned staff
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  case  Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)
  user  User?  @relation("EventClient", fields: [userId], references: [id], onDelete: SetNull)
  staff User?  @relation("EventStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@map("events")
}

// ----- App settings -----

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

enum VehicleCategory {
  car
  motorcycle
}

enum SalesListingStatus {
  available
  reserved
  sold
  /** Bank-transfer boost slip submitted; awaiting staff approval. */
  pending_boost
}

/** Public inventory: dealer (e.g. Sunset Scooters sync) vs private seller listings. */
enum SalesSellerKind {
  dealer
  private
}

model SalesVehicle {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  make             String
  model            String
  year             Int
  mileageKm        Int                @map("mileage_km")
  priceAmount      Int                @map("price_amount")
  priceCurrency    String             @default("THB") @map("price_currency")
  category         VehicleCategory
  sellerKind       SalesSellerKind    @default(private) @map("seller_kind")
  status           SalesListingStatus @default(available)
  heroMediaType    String             @default("image") @map("hero_media_type")
  heroImageUrl     String             @map("hero_image_url")
  heroVideoUrl     String?            @map("hero_video_url")
  imageUrls        Json               @map("image_urls")
  videoUrls        Json?              @map("video_urls")
  description      String             @db.Text
  specifications   Json?
  published        Boolean            @default(true)
  isBoosted        Boolean            @default(false) @map("is_boosted")
  boostExpiresAt   DateTime?          @map("boost_expires_at")
  /** Package key, e.g. 1w / 2w / 4w (see SALES_BOOST_PACKAGES). */
  boostTier        String?            @map("boost_tier")
  omiseChargeId    String?            @unique @map("omise_charge_id")
  boostProofDocumentId String?        @map("boost_proof_document_id")
  createdById      String?            @map("created_by_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isBoosted, boostExpiresAt])
  @@index([category, status, published])
  @@index([sellerKind, status, published])
  @@index([make, model, year])
  @@map("sales_vehicles")
}

enum PropertyType {
  condo
  house
  townhouse
  land
  commercial
  villa
}

enum PropertyListingType {
  sale
  rent
}

enum PropertyFurnished {
  unfurnished
  partially
  furnished
  not_applicable
}

/** Public real-estate inventory (sale / rent listings). */
model SalesProperty {
  id               String              @id @default(cuid())
  slug             String              @unique
  title            String
  propertyType     PropertyType        @map("property_type")
  listingType      PropertyListingType @default(sale) @map("listing_type")
  bedrooms         Int?
  bathrooms        Int?
  areaSqm          Int                 @map("area_sqm")
  landAreaSqm      Int?                @map("land_area_sqm")
  floor            Int?
  yearBuilt        Int?                @map("year_built")
  province         String
  district         String?
  neighborhood     String?
  priceAmount      Int                 @map("price_amount")
  priceCurrency    String              @default("THB") @map("price_currency")
  sellerKind       SalesSellerKind     @default(private) @map("seller_kind")
  status           SalesListingStatus  @default(available)
  furnished        PropertyFurnished   @default(not_applicable)
  heroMediaType    String              @default("image") @map("hero_media_type")
  heroImageUrl     String              @map("hero_image_url")
  heroVideoUrl     String?             @map("hero_video_url")
  imageUrls        Json                @map("image_urls")
  videoUrls        Json?               @map("video_urls")
  description      String              @db.Text
  specifications   Json?
  published        Boolean             @default(true)
  isBoosted        Boolean             @default(false) @map("is_boosted")
  boostExpiresAt   DateTime?           @map("boost_expires_at")
  boostTier        String?             @map("boost_tier")
  createdById      String?             @map("created_by_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isBoosted, boostExpiresAt])
  @@index([propertyType, status, published])
  @@index([listingType, status, published])
  @@index([sellerKind, status, published])
  @@index([province, district])
  @@map("sales_properties")
}
