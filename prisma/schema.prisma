// SiamEZ Platform - MySQL schema
// Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----- Users & Auth -----

enum UserRole {
  admin
  staff
  customer
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  passwordHash   String?   @map("password_hash")
  name           String?
  phone          String?
  image          String?
  role           UserRole  @default(customer)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  casesAsClient  Case[]            @relation("CaseClient")
  staffAssignments StaffAssignment[]
  caseNotes      CaseNote[]
  documents      Document[]        @relation("DocumentUploader")
  invoices       Invoice[]         @relation("InvoiceCustomer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ----- Services -----

enum ServiceType {
  fixed   // Pay immediately
  quote   // Request review, admin sets price, client pays later
}

model Service {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  shortDescription String? @map("short_description") @db.VarChar(500)
  description String      @db.Text
  type        ServiceType @default(quote)
  priceAmount Int?        @map("price_amount")   // in smallest currency unit (e.g. cents)
  priceCurrency String?   @map("price_currency") @default("THB")
  // JSON: dynamic form config (questions, required docs, etc.)
  formConfig  Json?       @map("form_config")
  sortOrder   Int         @default(0) @map("sort_order")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  cases Case[]
}

// ----- Cases (every booking becomes a case) -----

enum CaseStatus {
  new           // Just submitted
  under_review  // Staff reviewing (quote-based)
  quoted        // Quote sent to client
  awaiting_payment
  paid          // Payment received
  in_progress   // Work in progress
  pending_docs  // Waiting for client docs
  completed
  cancelled
}

model Case {
  id          String     @id @default(cuid())
  caseNumber  String     @unique @map("case_number") // e.g. SE-2026-00001
  userId      String     @map("user_id")
  serviceId   String     @map("service_id")
  status      CaseStatus @default(new)
  // Optional guest booking: store email/phone for non-logged-in
  guestEmail  String?    @map("guest_email")
  guestName   String?    @map("guest_name")
  guestPhone  String?    @map("guest_phone")
  // Snapshot of booking form answers (JSON)
  formData    Json?      @map("form_data")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  completedAt DateTime?  @map("completed_at")

  user     User     @relation("CaseClient", fields: [userId], references: [id], onDelete: Restrict)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quotes   Quote[]
  payments Payment[]
  documents Document[]
  staffAssignments StaffAssignment[]
  caseNotes CaseNote[]
  invoices Invoice[]
}

// ----- Quotes -----

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
}

model Quote {
  id         String      @id @default(cuid())
  caseId     String      @map("case_id")
  amount     Int         // smallest currency unit
  currency   String      @default("THB")
  status     QuoteStatus @default(draft)
  validUntil DateTime?   @map("valid_until")
  notes      String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  sentAt     DateTime?   @map("sent_at")

  case    Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

// ----- Payments (Stripe-backed) -----

enum PaymentType {
  full
  deposit
  additional
  refund
}

enum PaymentStatus {
  pending
  succeeded
  failed
  cancelled
  refunded
}

model Payment {
  id                    String        @id @default(cuid())
  caseId                String        @map("case_id")
  amount                Int           // smallest unit
  currency              String        @default("THB")
  status                PaymentStatus @default(pending)
  type                  PaymentType   @default(full)
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?       @map("stripe_charge_id")
  metadata              Json?         // e.g. invoiceId, quoteId
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Restrict)
}

// ----- Documents -----

model Document {
  id         String   @id @default(cuid())
  caseId     String   @map("case_id")
  uploadedBy String?  @map("uploaded_by") // userId or null for system
  name       String
  storageKey String   @map("storage_key") // Vercel Blob / S3 key or URL
  mimeType   String?  @map("mime_type")
  size       Int?     // bytes
  documentType String? @map("document_type") // e.g. passport, contract
  createdAt  DateTime @default(now()) @map("created_at")

  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploader User? @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
}

// ----- Staff assignments -----

model StaffAssignment {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  userId    String   @map("user_id")
  role      String   @default("support") // primary, support
  assignedAt DateTime @default(now()) @map("assigned_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
  @@map("staff_assignments")
}

// ----- Case notes (internal + client-visible) -----

model CaseNote {
  id         String   @id @default(cuid())
  caseId     String   @map("case_id")
  userId     String   @map("user_id")
  content    String   @db.Text
  isInternal Boolean  @default(true) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("case_notes")
}

// ----- Invoices -----

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id               String        @id @default(cuid())
  caseId           String        @map("case_id")
  quoteId          String?       @map("quote_id")
  userId           String        @map("user_id") // billing contact
  amount           Int
  currency         String        @default("THB")
  status           InvoiceStatus @default(draft)
  dueDate          DateTime?     @map("due_date")
  stripeInvoiceId  String?       @map("stripe_invoice_id")
  lineItems        Json?         @map("line_items")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  sentAt           DateTime?     @map("sent_at")
  paidAt           DateTime?     @map("paid_at")

  case   Case   @relation(fields: [caseId], references: [id], onDelete: Restrict)
  quote  Quote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  user   User   @relation("InvoiceCustomer", fields: [userId], references: [id], onDelete: Restrict)

  @@map("invoices")
}
