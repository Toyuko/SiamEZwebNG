// SiamEZ Platform - PostgreSQL schema
// Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- Users & Auth -----

enum UserRole {
  admin
  staff
  customer
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  passwordHash   String?   @map("password_hash")
  name           String?
  phone          String?
  image          String?
  timezone       String?
  preferredLocale String?  @map("preferred_locale")
  notificationPreferences Json? @map("notification_preferences")
  lastLoginAt    DateTime? @map("last_login_at")
  role           UserRole  @default(customer)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  casesAsClient  Case[]            @relation("CaseClient")
  staffAssignments StaffAssignment[]
  caseNotes      CaseNote[]
  documents      Document[]        @relation("DocumentUploader")
  invoices       Invoice[]         @relation("InvoiceCustomer")
  eventsAsClient Event[]           @relation("EventClient")
  eventsAsStaff  Event[]           @relation("EventStaff")
  salesVehiclesCreated SalesVehicle[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ----- Services -----

enum ServiceType {
  fixed   // Pay immediately
  quote   // Request review, admin sets price, client pays later
}

model Service {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  shortDescription String? @map("short_description") @db.VarChar(500)
  description String      @db.Text
  type        ServiceType @default(quote)
  priceAmount Int?        @map("price_amount")   // in smallest currency unit (e.g. cents)
  priceCurrency String?   @map("price_currency") @default("THB")
  // JSON: dynamic form config (questions, required docs, etc.)
  formConfig  Json?       @map("form_config")
  sortOrder   Int         @default(0) @map("sort_order")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  cases Case[]
}

// ----- Cases (every booking becomes a case) -----

enum CaseStatus {
  new           // Just submitted
  under_review  // Staff reviewing (quote-based)
  quoted        // Quote sent to client
  awaiting_payment
  paid          // Payment received
  in_progress   // Work in progress
  pending_docs  // Waiting for client docs
  completed
  cancelled
}

model Case {
  id                   String     @id @default(cuid())
  caseNumber           String     @unique @map("case_number") // e.g. SE-2026-00001
  userId               String?    @map("user_id") // null for guest bookings
  serviceId            String     @map("service_id")
  status               CaseStatus @default(new)
  isGuest              Boolean    @default(false) @map("is_guest")
  guestCheckoutToken   String?    @unique @map("guest_checkout_token") // for secure guest checkout
  guestEmail          String?    @map("guest_email")
  guestName           String?    @map("guest_name")
  guestPhone          String?    @map("guest_phone")
  formData            Json?      @map("form_data")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  completedAt         DateTime?  @map("completed_at")

  user     User?    @relation("CaseClient", fields: [userId], references: [id], onDelete: SetNull)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quotes   Quote[]
  payments Payment[]
  documents Document[]
  staffAssignments StaffAssignment[]
  caseNotes CaseNote[]
  invoices Invoice[]
  events   Event[]
}

// ----- Quotes -----

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
}

model Quote {
  id         String      @id @default(cuid())
  caseId     String      @map("case_id")
  amount     Int         // smallest currency unit
  currency   String      @default("THB")
  status     QuoteStatus @default(draft)
  validUntil DateTime?   @map("valid_until")
  notes      String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  sentAt     DateTime?   @map("sent_at")

  case    Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

// ----- Payments (provider-agnostic: QR, Bank, Wise, Stripe Phase 2) -----

enum PaymentMethod {
  qr      // Thai PromptPay / Bank QR
  bank    // Bank transfer
  wise    // Wise international
  stripe  // Phase 2: online payment
}

enum PaymentStatus {
  submitted   // Proof uploaded, awaiting admin review
  approved    // Admin approved -> invoice paid
  rejected    // Admin rejected
  // Stripe Phase 2: pending, succeeded, failed, refunded
}

model Payment {
  id                    String         @id @default(cuid())
  invoiceId             String         @map("invoice_id")
  caseId                String         @map("case_id") // denormalized for convenience
  amount                Int            // smallest unit
  currency              String         @default("THB")
  method                PaymentMethod
  status                PaymentStatus  @default(submitted)
  proofDocumentId       String?        @unique @map("proof_document_id")
  submittedAt           DateTime       @default(now()) @map("submitted_at")
  approvedAt            DateTime?      @map("approved_at")
  stripePaymentIntentId String?        @unique @map("stripe_payment_intent_id") // Phase 2
  stripeChargeId        String?        @map("stripe_charge_id")
  metadata              Json?
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Restrict)
  proofDocument Document? @relation("PaymentProof", fields: [proofDocumentId], references: [id], onDelete: SetNull)
}

// ----- Documents -----

model Document {
  id           String   @id @default(cuid())
  caseId       String?  @map("case_id") // null = not yet linked to a case
  uploadedBy   String?  @map("uploaded_by") // userId or null for system
  name         String
  storageKey   String   @map("storage_key") // Vercel Blob / S3 key or URL
  mimeType     String?  @map("mime_type")
  size         Int?     // bytes
  documentType String?  @map("document_type") // e.g. passport, contract, payment_proof
  createdAt    DateTime @default(now()) @map("created_at")

  case           Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  uploader       User?   @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
  paymentProof   Payment? @relation("PaymentProof")
}

// ----- Staff assignments -----

model StaffAssignment {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  userId    String   @map("user_id")
  role      String   @default("support") // primary, support
  assignedAt DateTime @default(now()) @map("assigned_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
  @@map("staff_assignments")
}

// ----- Case notes (internal + client-visible) -----

model CaseNote {
  id         String   @id @default(cuid())
  caseId     String   @map("case_id")
  userId     String   @map("user_id")
  content    String   @db.Text
  isInternal Boolean  @default(true) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("case_notes")
}

// ----- Invoices -----

enum InvoiceStatus {
  draft                // Admin editing
  unpaid               // Sent to client, awaiting payment
  pending_verification // Proof uploaded, admin reviewing
  paid                 // Payment approved
  rejected             // Payment rejected
}

enum InvoicePaymentMethod {
  qr     // Thai PromptPay / Bank QR
  bank   // Bank transfer
  wise   // Wise international
  stripe // Phase 2
}

model Invoice {
  id               String               @id @default(cuid())
  caseId           String               @map("case_id")
  quoteId          String?              @map("quote_id")
  userId           String?              @map("user_id") // billing contact; null for guest invoices
  amount           Int
  currency         String               @default("THB")
  status           InvoiceStatus        @default(draft)
  paymentMethod    InvoicePaymentMethod? @map("payment_method") // set when client selects
  dueDate          DateTime?            @map("due_date")
  stripeInvoiceId  String?              @map("stripe_invoice_id") // Phase 2
  lineItems        Json?                @map("line_items")
  attachedPdfUrl   String?              @map("attached_pdf_url") // admin-uploaded or external PDF (blob URL)
  clientAddress    String?              @map("client_address")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  sentAt           DateTime?            @map("sent_at")
  paidAt           DateTime?            @map("paid_at")

  case     Case     @relation(fields: [caseId], references: [id], onDelete: Restrict)
  quote    Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  user     User?    @relation("InvoiceCustomer", fields: [userId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@map("invoices")
}

// ----- Calendar Events -----

enum EventType {
  appointment
  deadline
  milestone
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  start       DateTime
  end         DateTime
  type        EventType @default(appointment)
  allDay      Boolean   @default(false) @map("all_day")
  color       String?   // optional: blue, red, emerald, amber, purple, cyan, pink, orange
  caseId      String?   @map("case_id")
  userId      String?   @map("user_id")   // client
  staffId     String?   @map("staff_id")  // assigned staff
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  case  Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)
  user  User?  @relation("EventClient", fields: [userId], references: [id], onDelete: SetNull)
  staff User?  @relation("EventStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@map("events")
}

// ----- App settings -----

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

enum VehicleCategory {
  car
  motorcycle
}

enum SalesListingStatus {
  available
  reserved
  sold
}

enum SalesHeroMediaType {
  image
  video
}

model SalesVehicle {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  make             String
  model            String
  year             Int
  mileageKm        Int                @map("mileage_km")
  priceAmount      Int                @map("price_amount")
  priceCurrency    String             @default("THB") @map("price_currency")
  category         VehicleCategory
  status           SalesListingStatus @default(available)
  heroMediaType    SalesHeroMediaType @default(image) @map("hero_media_type")
  heroImageUrl     String             @map("hero_image_url")
  heroVideoUrl     String?            @map("hero_video_url")
  imageUrls        Json               @map("image_urls")
  videoUrls        Json?              @map("video_urls")
  description      String             @db.Text
  specifications   Json?
  published        Boolean            @default(true)
  createdById      String?            @map("created_by_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category, status, published])
  @@index([make, model, year])
  @@map("sales_vehicles")
}
